[Unit]
Description=Wintarch First Boot Configuration
After=local-fs.target dbus.service
# Keep first-boot configuration ahead of Plasma Login Manager and its generic alias.
Before=plasmalogin.service display-manager.service
ConditionPathExists=!/var/lib/wintarch/first-boot-done

[Service]
Type=oneshot
ExecStart=/opt/wintarch/install/first-boot.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
